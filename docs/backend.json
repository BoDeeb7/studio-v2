
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Represents a makeup product in the store.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "imageUrls": {
          "type": "array",
          "items": { "type": "string" }
        },
        "categoryId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "categoryId", "imageUrls"]
    },
    "Category": {
      "title": "Category",
      "description": "Represents a product category (e.g., Face, Lips).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Store for makeup products."
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Store for product categories."
    }
  }
}
