
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * GLOBAL RULES
     * تم السماح بالوصول الكامل لضمان نجاح الحفظ اللحظي من كافة الأجهزة.
     */

    match /categories/{categoryId} {
      allow read, write: if true;
    }

    match /products/{productId} {
      allow read, write: if true;
    }

    match /{document=**} {
      allow read, write: if true;
    }

  }
}
