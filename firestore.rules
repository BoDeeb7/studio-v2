rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements a Database Access Control (DBAC) model tailored for a makeup artist's portfolio.
     * It prioritizes high availability for public content while strictly restricting management capabilities 
     * to verified administrative accounts.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user has an entry in the adminRoles collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/adminRoles/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Registry of administrative users.
     */
    match /adminRoles/{adminUid} {
      allow get: if isSignedIn() && request.auth.uid == adminUid;
      allow list: if false;
      allow create, update, delete: if false;
    }

    /**
     * @description Product Categories (e.g., Face, Lips).
     * Publicly viewable by everyone. Writable only by admins.
     */
    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Products/Services.
     * Publicly viewable by everyone. Writable only by admins.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

  }
}