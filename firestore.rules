
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * GLOBAL RULES
     * تم تحديث القواعد لضمان السماح بالوصول الكامل للأدمن ومزامنة الزوار.
     * التحديث الأخير: السماح العام لضمان استقرار النموذج الأولي.
     */

    match /categories/{categoryId} {
      allow read, write: if true;
    }

    match /products/{productId} {
      allow read, write: if true;
    }

    match /adminRoles/{adminUid} {
      allow get: if request.auth != null && request.auth.uid == adminUid;
      allow list, write: if false;
    }

  }
}
