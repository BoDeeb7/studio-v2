rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * تم تعديل القواعد للسماح لـ Hassan Deeb Studio بإدارة المنتجات والأقسام مباشرة.
     * في مرحلة الإنتاج، يفضل تقييد الكتابة للمسؤولين فقط عبر Firebase Auth.
     */

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // --- Collection Rules ---

    /**
     * @description Product Categories (الأقسام).
     * متاح للجميع حالياً لضمان عمل لوحة التحكم.
     */
    match /categories/{categoryId} {
      allow read, write: if true;
    }

    /**
     * @description Products/Services (المنتجات).
     * متاح للجميع حالياً لضمان عمل لوحة التحكم.
     */
    match /products/{productId} {
      allow read, write: if true;
    }

    /**
     * @description Admin Roles.
     */
    match /adminRoles/{adminUid} {
      allow get: if isSignedIn() && request.auth.uid == adminUid;
      allow list, write: if false;
    }

  }
}